pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Building project...'
                sh 'mvn clean package'  // Replace with your build command
            }
        }
        stage('Test') {
            steps {
                echo 'Running tests...'
                sh 'mvn test'  // Replace with your test command
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying application...'
                sh 'docker build -t my-app .'  // Replace with your deploy command
            }
        }
    }
}
